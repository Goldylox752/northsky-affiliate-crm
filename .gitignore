# ==========================================
# 1. Environment & Secret Variables (CRITICAL)
# ==========================================
# Never commit real keys, Twilio, or Supabase credentials!
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# 2. Next.js & Build Outputs
# ==========================================
/.next/
/out/
/build
/dist
/.vercel

# ==========================================
# 3. Dependencies
# ==========================================
/node_modules
/.pnpm-store
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml

# ==========================================
# 4. Debug Logs & Testing
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*
/coverage
.nyc_output

# ==========================================
# 5. OS & Editor Junk
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
/.idea
/.vscode/*
!/.vscode/settings.json
!/.vscode/tasks.json
!/.vscode/launch.json
!/.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

